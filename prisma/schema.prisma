
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  displayName  String
  authProvider String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
